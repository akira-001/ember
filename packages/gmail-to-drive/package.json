{
  "name": "@ember/gmail-to-drive",
  "version": "1.0.0",
  "private": true,
  "description": "Apps Script for archiving Gmail invoices/receipts to Drive (replaces gmail_to_drive.py + claude.ai routine)",
  "scripts": {
    "clasp:login": "clasp login",
    "clasp:create": "clasp create --type standalone --title 'Gmail to Drive' --rootDir ./src",
    "clasp:push": "clasp push --force",
    "clasp:pull": "clasp pull",
    "clasp:open": "clasp open"
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2"
  }
}
